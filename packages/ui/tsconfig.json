{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "#components/*": ["./src/components/*"],
      "#lib/*": ["./src/lib/*"],
      "#hooks/*": ["./src/hooks/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
